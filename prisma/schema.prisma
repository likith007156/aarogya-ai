generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Patient {
  id               String   @id @default(cuid())
  name             String
  age              Int
  village          String
  riskLevel        String   // "HIGH", "MEDIUM", "LOW"
  suspectedDisease String?
  abhaId           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PHC {
  id        String   @id @default(cuid())
  name      String
  latitude  Float
  longitude Float
  slots     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
